# Environment Variables Template
# Copy this to .dev.vars for local development
# Add these to Cloudflare Pages dashboard for production

# Email Configuration for Cloudflare Email Workers
# Prerequisites:
# 1. Enable Email Routing for your domain in Cloudflare dashboard
# 2. Verify the RECIPIENT_EMAIL address in Email Routing destinations
# 3. FROM_EMAIL must be from your verified domain (e.g., noreply@oredrok.dev)

# Required: Your email address where contact form submissions will be sent
# This must be verified in Cloudflare Email Routing
RECIPIENT_EMAIL=your-email@example.com

# Optional: Custom sender email (must be from your verified domain)
# Defaults to noreply@oredrok.dev
FROM_EMAIL=noreply@oredrok.dev
