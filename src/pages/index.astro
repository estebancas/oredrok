---
import PageLayout from '../components/layout/PageLayout.astro';
import HeroSection from '../components/sections/HeroSection.svelte';
import AboutSection from '../components/sections/AboutSection.svelte';
import ProjectsSection from '../components/sections/ProjectsSection.svelte';
import ContactSection from '../components/sections/ContactSection.svelte';
---

<PageLayout
  title="Oredrok | Software Wizard"
  description="Pixel-perfect portfolio of Oredrok, a software wizard crafting digital experiences with retro charm and modern tech"
>
  <!-- Hero Section -->
  <HeroSection client:load />

  <!-- About Section with Comparison Cards -->
  <AboutSection client:visible />

  <!-- Projects Showcase -->
  <ProjectsSection client:visible />

  <!-- Contact Form -->
  <ContactSection client:visible />
</PageLayout>
