# Email Worker URL
# IMPORTANT: This variable must be set in Cloudflare Pages dashboard for production builds
# Go to: Settings > Environment variables > Add variable
# Name: PUBLIC_WORKER_URL
# Value: https://oredrok-email-worker.your-subdomain.workers.dev/contact
#
# For local development, use localhost (or create a .env file):
PUBLIC_WORKER_URL=http://localhost:8788/contact
