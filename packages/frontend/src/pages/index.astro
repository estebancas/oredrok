---
import { getCollection } from 'astro:content';
import PageLayout from '../components/layout/PageLayout.astro';
import HeroSection from '../components/sections/HeroSection.svelte';
import AboutSection from '../components/sections/AboutSection.svelte';
import ProjectsSection from '../components/sections/ProjectsSection.svelte';
import ContactSection from '../components/sections/ContactSection.svelte';
import Footer from '../components/layout/Footer.svelte';

// Fetch projects from content collections
const allProjects = await getCollection('projects');
const projects = allProjects
  .sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999))
  .map((project) => ({
    title: project.data.title,
    description: project.data.contribution, // Use contribution as the card description
    image: project.data.image,
    tags: project.data.techStack, // Use techStack as tags
    role: project.data.role,
    href: `/projects/${project.slug}`, // Internal link to detail page
    liveUrl: project.data.liveUrl || undefined, // External link for detail page
    appStoreUrl: project.data.appStoreUrl || undefined,
    playStoreUrl: project.data.playStoreUrl || undefined,
    cta: project.data.appStoreUrl || project.data.playStoreUrl ? 'View App' : 'View Details',
  }));
---

<PageLayout
  title="Oredrok | Software Wizard"
  description="Pixel-perfect portfolio of Oredrok, a software wizard crafting digital experiences with the range of a modern renaissance developer"
>
  <!-- Hero Section -->
  <HeroSection client:load />

  <!-- About Section with Comparison Cards -->
  <AboutSection client:visible />

  <!-- Projects Showcase -->
  <ProjectsSection projects={projects} client:visible />

  <!-- Contact Form -->
  <ContactSection client:visible />

  <!-- Footer (Main Page Only) -->
  <Footer client:visible />
</PageLayout>

<script>
  // Handle hash navigation on page load
  if (typeof window !== 'undefined') {
    window.addEventListener('load', () => {
      const hash = window.location.hash;
      if (hash) {
        // Small delay to ensure the page is fully rendered
        setTimeout(() => {
          const element = document.querySelector(hash);
          if (element) {
            element.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        }, 100);
      }
    });

    // Also handle hash changes during navigation
    window.addEventListener('hashchange', () => {
      const hash = window.location.hash;
      if (hash) {
        const element = document.querySelector(hash);
        if (element) {
          element.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      }
    });
  }
</script>
