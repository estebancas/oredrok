---
import { getCollection, type CollectionEntry } from 'astro:content';
import PageLayout from '../../components/layout/PageLayout.astro';
import PixelButton from '../../components/ui/PixelButton.svelte';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<PageLayout title={post.data.title}>
  <main class="blog-post">
    <div class="post-container">
      <!-- Back Button -->
      <div class="back-button">
        <PixelButton
          variant="outline"
          size="sm"
          href="/blog"
          client:load
        >
          ◄ Back to Blog
        </PixelButton>
      </div>

      <!-- Post Header -->
      <header class="post-header">
        <h1 class="post-title pixel-header">{post.data.title}</h1>

        <div class="post-meta pixel-label">
          <time datetime={post.data.publishedDate.toISOString()}>
            {post.data.publishedDate.toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })}
          </time>
          <span class="separator">•</span>
          <span>{post.data.author}</span>
        </div>

        {post.data.tags.length > 0 && (
          <div class="post-tags">
            {post.data.tags.map((tag) => (
              <span class="tag pixel-label">{tag}</span>
            ))}
          </div>
        )}
      </header>

      <!-- Featured Image -->
      {post.data.image && (
        <div class="post-image-container">
          <img
            src={post.data.image}
            alt={post.data.title}
            class="post-image"
          />
        </div>
      )}

      <!-- Post Content -->
      <article class="post-content prose">
        <Content />
      </article>

      <!-- Footer -->
      <footer class="post-footer">
        <div class="footer-divider"></div>
        <PixelButton
          variant="blue"
          size="lg"
          href="/blog"
          client:load
        >
          ◄ View All Posts
        </PixelButton>
      </footer>
    </div>
  </main>
</PageLayout>

<style>
  .blog-post {
    min-height: 100vh;
    background: var(--bg-primary);
    padding: var(--spacing-4xl) var(--spacing-lg);
  }

  .post-container {
    max-width: 800px;
    margin: 0 auto;
  }

  .back-button {
    margin-bottom: var(--spacing-2xl);
  }

  .post-header {
    margin-bottom: var(--spacing-4xl);
    text-align: center;
  }

  .post-title {
    font-size: clamp(28px, 5vw, 42px);
    color: var(--text-primary);
    margin-bottom: var(--spacing-lg);
    line-height: 1.3;
    text-shadow:
      3px 3px 0 var(--accent-green),
      6px 6px 0 var(--bg-secondary);
  }

  .post-meta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-sm);
    font-size: 10px;
    color: var(--accent-blue);
    margin-bottom: var(--spacing-lg);
    text-transform: uppercase;
  }

  .separator {
    color: var(--text-secondary);
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
    justify-content: center;
  }

  .tag {
    background: var(--bg-secondary);
    color: var(--accent-green);
    padding: 6px 12px;
    border: 2px solid var(--border-pixel);
    border-radius: var(--radius-sm);
    font-size: 10px;
    text-transform: uppercase;
  }

  .post-image-container {
    margin-bottom: var(--spacing-4xl);
    border: var(--border-pixel) solid var(--border-light);
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--bg-secondary);
    box-shadow: 8px 8px 0 var(--accent-green-dark);
  }

  .post-image {
    width: 100%;
    height: auto;
    display: block;
  }

  .post-content {
    margin-bottom: var(--spacing-4xl);
  }

  /* Markdown Content Styling */
  .prose {
    color: var(--text-secondary);
    line-height: 1.8;
  }

  .prose :global(h1),
  .prose :global(h2),
  .prose :global(h3),
  .prose :global(h4) {
    font-family: 'Press Start 2P', monospace;
    color: var(--text-primary);
    margin-top: var(--spacing-3xl);
    margin-bottom: var(--spacing-lg);
    line-height: 1.4;
  }

  .prose :global(h1) {
    font-size: clamp(24px, 4vw, 32px);
    color: var(--accent-green);
  }

  .prose :global(h2) {
    font-size: clamp(20px, 3vw, 26px);
    color: var(--accent-blue);
  }

  .prose :global(h3) {
    font-size: clamp(16px, 2vw, 20px);
  }

  .prose :global(p) {
    margin-bottom: var(--spacing-xl);
    font-size: 15px;
    line-height: 1.8;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin-bottom: var(--spacing-xl);
    padding-left: var(--spacing-2xl);
  }

  .prose :global(li) {
    margin-bottom: var(--spacing-md);
    font-size: 15px;
    line-height: 1.7;
  }

  .prose :global(strong) {
    color: var(--accent-blue);
    font-weight: bold;
  }

  .prose :global(em) {
    color: var(--accent-green);
    font-style: italic;
  }

  .prose :global(code) {
    background: var(--bg-secondary);
    color: var(--accent-green);
    padding: 4px 8px;
    border-radius: var(--radius-sm);
    font-family: 'Courier New', monospace;
    font-size: 13px;
  }

  .prose :global(pre) {
    background: var(--bg-secondary);
    border: 2px solid var(--border-pixel);
    border-radius: var(--radius-md);
    padding: var(--spacing-lg);
    overflow-x: auto;
    margin-bottom: var(--spacing-xl);
  }

  .prose :global(pre code) {
    background: transparent;
    padding: 0;
  }

  .prose :global(blockquote) {
    border-left: 4px solid var(--accent-blue);
    padding-left: var(--spacing-lg);
    margin: var(--spacing-xl) 0;
    font-style: italic;
    color: var(--text-secondary);
  }

  .prose :global(a) {
    color: var(--accent-blue);
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .prose :global(a:hover) {
    color: var(--accent-green);
  }

  .prose :global(hr) {
    border: none;
    border-top: 2px solid var(--border-pixel);
    margin: var(--spacing-3xl) 0;
  }

  .post-footer {
    padding-top: var(--spacing-3xl);
  }

  .footer-divider {
    border-top: 2px solid var(--border-pixel);
    margin-bottom: var(--spacing-2xl);
  }

  .post-footer {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .blog-post {
      padding: var(--spacing-2xl) var(--spacing-md);
    }

    .post-title {
      text-shadow:
        2px 2px 0 var(--accent-green),
        4px 4px 0 var(--bg-secondary);
    }

    .post-meta {
      flex-direction: column;
      gap: var(--spacing-xs);
    }

    .separator {
      display: none;
    }
  }
</style>
